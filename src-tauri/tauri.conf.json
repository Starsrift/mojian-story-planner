{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "墨笺",
  "version": "0.1.0",
  "identifier": "com.starsrift.mojian",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "墨笺 · 小说策划台",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
