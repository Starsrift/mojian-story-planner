{
  "name": "mojian-story-planner",
  "productName": "Mojian Story Planner",
  "description": "A desktop workspace for planning stories and organizing narrative structure.",
  "author": {
    "name": "edward-win",
    "email": "aetherwyrm@vip.163.com"
  },
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "clean:release": "node scripts/clean-release.mjs",
    "electron:build": "npm run install:electron && npm run build && npm run build:electron && npm run clean:release && node scripts/package-electron.mjs",
    "electron:dev": "npm run install:electron && node scripts/electron-dev.mjs",
    "dist:win": "npm run install:electron && npm run build && npm run build:electron && npm run clean:release && electron-builder --win nsis zip --x64",
    "dist:mac": "npm run install:electron && npm run build && npm run build:electron && npm run clean:release && node scripts/package-mac.mjs",
    "install:electron": "node node_modules/electron/install.js",
    "preview": "vite preview",
    "check:workflows": "prettier --check \".github/workflows/*.yml\"",
    "test": "vitest",
    "test:run": "vitest run",
    "verify:release": "node scripts/verify-release-artifacts.mjs"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xyflow/react": "^12.11.2",
    "d3": "^7.9.0",
    "dexie": "^4.4.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prettier": "3.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "yaml": "2.8.2",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.starsrift.mojian",
    "artifactName": "mojian-story-planner-${version}-${os}-${arch}.${ext}",
    "afterPack": "scripts/after-pack.mjs",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/main.js",
      "dist-electron/navigationPolicy.js",
      "dist-electron/runtime.js",
      "dist-electron/preload.cjs",
      "!dist-electron/**/*.map",
      "!node_modules/**"
    ],
    "win": {
      "signExecutable": false,
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
